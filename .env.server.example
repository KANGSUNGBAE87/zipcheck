# Server/agent/CI-only placeholders. Do not copy these into browser env files.
# Real values belong in Supabase Edge Function secrets, backend runtime env, or local private env.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-to-server Toss login exchange endpoint backed by Apps in Toss mTLS material.
TOSS_LOGIN_TOKEN_EXCHANGE_URL=

# Shared secret accepted by the ZipCheck disconnect callback route.
TOSS_DISCONNECT_CALLBACK_SECRET=

# Official Apps in Toss disconnect callback Basic Auth credentials.
TOSS_DISCONNECT_CALLBACK_BASIC_USERNAME=
TOSS_DISCONNECT_CALLBACK_BASIC_PASSWORD=

# HMAC secret used to hash official callback userKey values into providerSubjectHash.
TOSS_USER_KEY_HASH_SECRET=

# Comma-separated CORS allowlist for Edge Functions.
ZIPCHECK_ALLOWED_ORIGINS=

# Non-secret local Apps in Toss sandbox/build overrides.
APPS_IN_TOSS_WEB_HOST=
APPS_IN_TOSS_ICON_URL=

# Server/agent-only Apps in Toss Console automation key.
APPS_IN_TOSS_CONSOLE_API_KEY=
